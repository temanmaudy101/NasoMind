# Contoh isi secrets. JANGAN commit key asli ke GitHub.
# Lokal: salin menjadi .streamlit/secrets.toml.
# Streamlit Cloud: isi lewat menu App -> Settings -> Secrets.

# ===== 1) Chat AI: cukup isi SALAH SATU key =====
# Gemini (GRATIS, disarankan) - ambil di https://aistudio.google.com
GEMINI_API_KEY = "AIza_xxxxxxxx"
# ANTHROPIC_API_KEY = "sk-ant-xxxxxxxx"
# OPENAI_API_KEY = "sk-xxxxxxxx"

# ===== 2) Login Google untuk pasien (OIDC) =====
# Catatan TOML: blok [auth] HARUS diletakkan setelah key di atas.
[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
# Saat sudah online, ganti redirect_uri menjadi:
# "https://NAMAAPLIKASI.streamlit.app/oauth2callback"
cookie_secret = "ganti-dengan-string-acak-yang-panjang"
client_id = "xxxxxxxx.apps.googleusercontent.com"
client_secret = "xxxxxxxx"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
